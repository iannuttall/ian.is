{
  "name": "ian-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm -C apps/site dev",
    "dev:cf": "pnpm -C apps/site dev:cf",
    "build": "pnpm -C apps/site build",
    "preview": "pnpm -C apps/site preview",
    "astro": "node scripts/astro.mjs",
    "generate-types": "pnpm -C apps/site generate-types",
    "build:sitemaps": "pnpm -C apps/site build:sitemaps",
    "data:refresh": "pnpm -C apps/site data:refresh",
    "site:deploy": "pnpm -C apps/site deploy",
    "site:worker:deploy": "pnpm -C apps/site deploy:built",
    "ian": "node packages/ian/bin/ian.mjs",
    "security:audit": "pnpm audit",
    "security:secrets": "gitleaks detect --source . --redact --no-banner --verbose",
    "security:check": "pnpm run security:audit && pnpm run security:secrets",
    "newsletter:build": "pnpm --filter email build",
    "newsletter:clean": "pnpm --filter email clean",
    "newsletter:email:preview": "pnpm --filter email email:preview",
    "newsletter:lint": "pnpm --filter email lint",
    "newsletter:lint:fix": "pnpm --filter email lint:fix",
    "newsletter:test": "pnpm --filter email test",
    "newsletter:typecheck": "pnpm --filter email typecheck",
    "newsletter:web:dev": "pnpm --filter @email/web dev"
  },
  "devDependencies": {
    "turbo": "^2.5.5"
  }
}
