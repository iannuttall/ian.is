  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@email/api": "workspace:*",
    "@email/core": "workspace:*",
    "@email/mcp": "workspace:*",
    "citty": "^0.1.6",
    "picocolors": "^1.1.1",
    "zod": "^4.1.13"
