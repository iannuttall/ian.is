# Local and VPS runtime
APP_NAME=email
EMAIL_APP_NAME=My Newsletter
MAIN_SITE_NAME=Example
MAIN_SITE_URL=https://example.com
APP_DOMAIN=newsletter.example.com
APP_HOSTS=newsletter.example.com
APP_HOSTS_LIST=newsletter.example.com
APP_PORT=3000
WEB_PORT=3002
APP_HOST_BIND=127.0.0.1
APP_HOST_PORT=3001
WEB_HOST_PORT=3002
APP_IMAGE=email:local

# Local development Postgres port
POSTGRES_PORT=55433

# Production Postgres container settings
POSTGRES_DB=email
POSTGRES_USER=email
POSTGRES_PASSWORD=change-me

# Required in deployed environments
DATABASE_URL=postgresql://email:email@localhost:55433/email
BASE_URL=https://newsletter.example.com
EMAIL_API_INTERNAL_URL=http://app:3000
API_TOKEN=change-me
UNSUBSCRIBE_SECRET=change-me
TRACKING_SECRET=change-me
EMAIL_PROVIDER=ses
EMAIL_FROM_EMAIL=newsletter@example.com
EMAIL_FROM_NAME=My Newsletter
EMAIL_TRACK_OPENS=true
EMAIL_SEND_RATE_PER_SECOND=14

# Required only when using the SES provider
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_WEBHOOK_SECRET=change-me
AWS_SNS_ALLOWED_TOPICS=
