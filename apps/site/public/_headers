/*
  Cache-Control: public, max-age=600, s-maxage=2592000, stale-while-revalidate=86400
  Content-Signal: search=yes, ai-input=yes, ai-train=yes
  Strict-Transport-Security: max-age=31536000
  Link: <https://ian.is/sitemap.xml>; rel="sitemap"; type="application/xml"
  Link: <https://ian.is/llms.txt>; rel="llms-txt"; type="text/markdown"
  Link: <https://ian.is/.well-known/agent-skills/index.json>; rel="agent-skills"; type="application/json"

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Long-term immutable caching for self-hosted fonts (stable filenames).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/favicon*
  Cache-Control: public, max-age=86400, s-maxage=2592000, stale-while-revalidate=604800

/logo-*
  Cache-Control: public, max-age=86400, s-maxage=2592000, stale-while-revalidate=604800

/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400

/sitemaps/*
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400

/robots.txt
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400

/rss.xml
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400

/llms.txt
  ! Cache-Control
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff

/.well-known/agent-skills/index.json
  ! Cache-Control
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: application/json; charset=utf-8
  X-Content-Type-Options: nosniff

/.well-known/agent-skills/*/SKILL.md
  ! Cache-Control
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300, must-revalidate
  Content-Type: text/markdown; charset=utf-8
  X-Content-Type-Options: nosniff
