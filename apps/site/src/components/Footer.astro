---
import Logo from './Logo.astro'
import { externalLinkAttrs } from "@/lib/external-links.mjs";

const linkRows = [
  [
    { label: 'Posts', href: '/posts' },
    { label: 'Tools', href: '/tools' },
  ],
  [
    { label: 'Terms', href: '/terms' },
    { label: 'Privacy', href: '/privacy' },
    { label: 'Cookies', href: '/cookies' },
  ],
]

const linkClass =
  'text-sm/6 text-foreground-muted underline-offset-2 transition-colors hover:text-foreground hover:underline hover:decoration-dotted'
---

<footer class="mt-20 py-14">
  <div class="site-frame flex flex-col items-center gap-8 text-center">
    <a href="/" class="text-foreground no-underline" aria-label="Ian Nuttall home">
      <Logo class="text-2xl" />
    </a>

    <nav class="flex flex-col items-center gap-4" aria-label="Footer">
      {
        linkRows.map((row) => (
          <ul class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3">
            {row.map((link) => (
              <li>
                <a class={linkClass} {...externalLinkAttrs(link.href)}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        ))
      }
      <a
        class="text-2xl/none text-foreground underline-offset-2 transition-colors hover:text-foreground-muted hover:underline hover:decoration-dotted"
        {...externalLinkAttrs("https://x.com/iannuttall")}
        aria-label="Ian Nuttall on X"
      >
        𝕏
      </a>
    </nav>

    <p class="text-xs text-foreground-soft">
      &copy; {new Date().getFullYear()} Ian Nuttall
    </p>
  </div>
</footer>
