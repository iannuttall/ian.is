---
type Props = {
  title: string;
  href?: string;
  meta?: string;
  external?: boolean;
};

import ExternalLink from "@/components/icons/ExternalLink.astro";
import { externalLinkAttrs, isExternalHref } from "@/lib/external-links.mjs";

const { title, href, meta, external } = Astro.props;
const hasHref = typeof href === "string" && href.length > 0;
const linkAttrs = hasHref ? externalLinkAttrs(href) : {};
const isExternal = hasHref && (external ?? isExternalHref(href));
const Element = hasHref ? "a" : "div";
---

<li class="flex">
  <Element
    {...linkAttrs}
    class:list={[
      "inline-flex flex-1 items-baseline gap-2 no-underline",
      hasHref ? "group/list-item" : null,
    ]}
  >
    <span
      class:list={[
        "text-xl leading-[1.6] font-medium tracking-normal text-foreground underline-offset-1",
        hasHref
          ? "group-hover/list-item:underline group-hover/list-item:decoration-dotted"
          : null,
      ]}
    >
      {title}
    </span>
    {isExternal ? (
      <ExternalLink
        class="size-5 shrink-0 translate-y-0.5 text-foreground"
        aria-hidden="true"
      />
    ) : null}
    <div class="hidden text-xl leading-[1.6] font-medium tracking-normal text-foreground-soft sm:block [&>p]:m-0">
      <slot />
    </div>
    {meta ? (
      <span class="ml-auto hidden shrink-0 text-xl leading-[1.6] font-medium tracking-normal text-foreground-soft sm:inline">
        {meta}
      </span>
    ) : null}
  </Element>
</li>
