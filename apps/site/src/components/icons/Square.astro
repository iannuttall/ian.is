---
type Props = {
  size?: string | number;
  strokeWidth?: string | number;
  [key: string]: unknown;
};

const { size = 20, strokeWidth = 2.5, ...props } = Astro.props as Props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 256 256"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  {...props}
>
  <rect x="32" y="32" width="192" height="192" rx="16"/>
</svg>
