---
interface Props {
  size?: number;
  /** id of the element this button expands (for aria-controls). */
  controls?: string;
  class?: string;
}
const { size = 24, controls, class: className } = Astro.props;
---

<button
  type="button"
  class:list={[
    "group/menu inline-flex items-center justify-center text-foreground",
    "transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background",
    className,
  ]}
  x-data="menuToggle"
  x-on:click="toggle"
  aria-label="Toggle menu"
  aria-expanded="false"
  x-bind:aria-expanded="String(open)"
  aria-controls={controls}
>
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    class="overflow-visible"
    aria-hidden="true"
  >
    <path
      d="M3 9C3 8.44772 3.44772 8 4 8L20 8C20.5523 8 21 8.44772 21 9C21 9.55229 20.5523 10 20 10L4 10C3.44772 10 3 9.55228 3 9Z"
      fill="currentColor"
      fill-rule="evenodd"
      clip-rule="evenodd"
      class="[transform-box:view-box] origin-[12px_9px] transition-transform duration-200 ease-in-out motion-reduce:transition-none group-aria-expanded/menu:[transform:translateY(3px)_rotate(45deg)]"
    />
    <path
      d="M3 15C3 14.4477 3.44772 14 4 14L14 14C14.5523 14 15 14.4477 15 15C15 15.5523 14.5523 16 14 16L4 16C3.44772 16 3 15.5523 3 15Z"
      fill="currentColor"
      fill-rule="evenodd"
      clip-rule="evenodd"
      class="[transform-box:view-box] origin-[9px_15px] transition-transform duration-200 ease-in-out motion-reduce:transition-none group-aria-expanded/menu:[transform:translate(3px,-3px)_rotate(-45deg)_scaleX(1.5)]"
    />
  </svg>
</button>
