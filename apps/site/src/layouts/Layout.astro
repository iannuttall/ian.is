---
import Header from "@/components/Header.astro";
import MenuOverlay from "@/components/MenuOverlay.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { newsletterSubscribedKey } from "@/lib/newsletter";
import { breadcrumbSchema, type SeoBreadcrumbItem } from "@/lib/seo";
import {
  adsenseClientId,
  clickySiteId,
  defaultOgImagePath,
  googleAnalyticsId,
  siteDescription,
  siteName,
  siteUrl,
} from "@/lib/site";
import "@/styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noIndex?: boolean;
  ogType?: "website" | "article";
  ogImagePath?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs?: SeoBreadcrumbItem[] | false;
  titleTemplate?: boolean;
  /** Hide the shared header/footer chrome (e.g. minimal/auth pages). */
  minimal?: boolean;
}

const {
  title = siteName,
  description = siteDescription,
  canonicalPath = Astro.url.pathname,
  noIndex = false,
  ogType = "website",
  ogImagePath = defaultOgImagePath,
  structuredData,
  breadcrumbs,
  titleTemplate = true,
  minimal = false,
} = Astro.props;

const fullTitle = titleTemplate && title !== siteName ? `${title} | ${siteName}` : title;
const baseUrl = Astro.site ?? new URL(siteUrl);
const canonicalUrl = new URL(canonicalPath, baseUrl).toString();
const ogImageUrl = new URL(ogImagePath, baseUrl).toString();
const structuredDataList = (Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : []).filter(Boolean);
const isHome = canonicalPath === "/" || canonicalPath === "";
const breadcrumbItems =
  breadcrumbs === false
    ? []
    : breadcrumbs ?? (isHome || minimal ? [] : pageBreadcrumbs(title, canonicalPath));
if (breadcrumbItems.length > 1) {
  structuredDataList.push(breadcrumbSchema(breadcrumbItems, canonicalPath));
}
const isLocalHost = ["localhost", "127.0.0.1", "::1"].includes(Astro.url.hostname);
const shouldLoadThirdPartyScripts = import.meta.env.PROD && !isLocalHost;
const hasClicky = clickySiteId.length > 0;
const hasGoogleAnalytics = googleAnalyticsId.length > 0;
const hasAdsense = adsenseClientId.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline define:vars={{ newsletterSubscribedKey }}>
      try {
        if (window.localStorage.getItem(newsletterSubscribedKey) === "true") {
          document.documentElement.dataset.newsletterSubscribed = "true";
        }
      } catch {}
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    {["/fonts/sans-400.woff2", "/fonts/sans-500.woff2", "/fonts/sans-600.woff2"].map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin="anonymous" />
    ))}
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/png" href="/favicon-light.png?v=20260706-2" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png?v=20260706-2" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/favicon-light.png?v=20260706-2" />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : null}
    <title>{fullTitle}</title>
    {shouldLoadThirdPartyScripts && hasClicky ? (
      <script is:inline async data-id={clickySiteId} src="https://static.getclicky.com/js"></script>
    ) : null}
    {shouldLoadThirdPartyScripts && hasGoogleAnalytics ? (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
        <script is:inline define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAnalyticsId);
        </script>
      </>
    ) : null}
    {shouldLoadThirdPartyScripts && hasAdsense ? (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    ) : null}
    {shouldLoadThirdPartyScripts ? <slot name="third-party-scripts" /> : null}
    {structuredDataList.map((entry) => <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />)}
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-background antialiased">
    <a href="#content" class="skip-link">Skip to content</a>
    <div class="flex min-h-screen flex-col">
      {minimal ? null : <Header breadcrumbs={breadcrumbItems} />}
      {minimal ? null : <MenuOverlay />}
      <main id="content" class="flex-1">
        <slot />
      </main>
    </div>
    <script>
      import Alpine from "alpinejs";
      import setupAlpine from "@/scripts/alpine";

      setupAlpine(Alpine);
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
