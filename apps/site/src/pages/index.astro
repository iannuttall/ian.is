---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import ProjectsSection from "@/components/page/ProjectsSection.astro";
import PostListSection from "@/components/posts/PostListSection.astro";
import { getPublishedPosts } from "@/lib/posts";
import { webSiteSchema } from "@/lib/seo";

const posts = (await getPublishedPosts()).slice(0, 5);
---

<Layout
  title="Ian Nuttall - Marketer, SEO, Software Developer and AI"
  titleTemplate={false}
  description="Part entrepreneur, part marketer, part software engineer using AI to build stuff on the internet."
  canonicalPath="/"
  structuredData={webSiteSchema()}
>
  <section class="flex flex-col border-b border-border bg-background pt-4 text-foreground">
    <div class="site-frame">
      <div class="flex flex-col gap-8 pt-16 sm:pt-24">
        <div class="flex max-w-2xl flex-col gap-4">
          <h1 class="max-w-xl text-pretty text-3xl font-medium -tracking-[0.5px] xl:text-4xl xl:-tracking-[0.7px]">
            Ian Nuttall
          </h1>
          <p class="text-pretty text-2xl/8 font-medium -tracking-[0.2px] text-foreground-muted xl:text-3xl/10 xl:-tracking-[0.4px]">
            Part entrepreneur, part marketer, part software engineer using AI to build stuff on the internet.
          </p>
        </div>
        <Newsletter standalone={false} />
      </div>
    </div>
  </section>

  <div class="space-y-24 py-24">
    <section class="site-frame">
      <ProjectsSection />
    </section>

    <section class="site-frame">
      <PostListSection posts={posts} href="/posts" postHeadingLevel="h3" />
    </section>
  </div>
</Layout>
