---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import PostListSection from "@/components/posts/PostListSection.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { getPublishedPosts } from "@/lib/posts";
import { webPageSchema } from "@/lib/seo";

const posts = await getPublishedPosts();
const structuredData = webPageSchema({
  title: "Posts",
  description: "Writing on SEO, AI, and building tools.",
  path: "/posts",
  type: "CollectionPage",
});
---

<Layout
  title="Posts"
  description="Writing on SEO, AI, and building tools."
  canonicalPath="/posts"
  breadcrumbs={pageBreadcrumbs("Posts", "/posts")}
  structuredData={structuredData}
>
  <div class="site-frame py-10">
    <PostListSection posts={posts} labelHeadingLevel="h1" />

    <a
      href="/tags"
      class="mt-6 inline-flex text-sm text-foreground-muted underline-offset-2 hover:text-foreground hover:underline hover:decoration-dotted"
    >
      Browse posts by topic
    </a>

    <div class="mt-16">
      <Newsletter />
    </div>
  </div>
</Layout>
