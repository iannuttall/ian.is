---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import PageHeader from "@/components/page/PageHeader.astro";
import PostTitleList from "@/components/posts/PostTitleList.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { getPublishedPosts } from "@/lib/posts";
import { webPageSchema } from "@/lib/seo";

const posts = await getPublishedPosts();
const structuredData = webPageSchema({
  title: "Posts",
  description: "Writing on SEO, AI, and building tools.",
  path: "/posts",
  type: "CollectionPage",
});
---

<Layout
  title="Posts"
  description="Writing on SEO, AI, and building tools."
  canonicalPath="/posts"
  breadcrumbs={pageBreadcrumbs("Posts", "/posts")}
  structuredData={structuredData}
>
  <div class="site-frame py-12 sm:py-16">
    <PageHeader title="Posts" subtitle="Writing on SEO, AI, and building tools." />

    <div class="mt-12">
      {posts.length === 0 ? (
        <p class="text-foreground-muted">No posts yet. Check back soon.</p>
      ) : (
        <PostTitleList posts={posts} headingLevel="h2" />
      )}
    </div>

    <a
      href="/tags"
      class="mt-6 inline-flex text-sm text-foreground-muted underline-offset-2 hover:text-foreground hover:underline hover:decoration-dotted"
    >
      Browse posts by topic
    </a>

    <div class="mt-16">
      <Newsletter />
    </div>
  </div>
</Layout>
