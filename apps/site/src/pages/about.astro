---
export const prerender = true;

import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { profilePageSchema } from "@/lib/seo";

const page = await getEntry("pages", "about");

if (!page) {
  throw new Error("Missing about page content.");
}

const { Content } = await render(page);
const title = page.data.title;
const description = page.data.description;
const path = "/about";

const structuredData = profilePageSchema({
  title: page.data.headline,
  description,
  path,
});
---

<Layout
  title={title}
  description={description}
  ogTitle={page.data.ogTitle}
  ogDescription={page.data.ogDescription}
  canonicalPath={path}
  breadcrumbs={pageBreadcrumbs(page.data.breadcrumbTitle ?? title, path)}
  structuredData={structuredData}
>
  <article>
    <Content />
  </article>
</Layout>
