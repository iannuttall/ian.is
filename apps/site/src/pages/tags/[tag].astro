---
export const prerender = true;

import PostCard from "@/components/posts/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/page/PageHeader.astro";
import { tagBreadcrumbs } from "@/lib/breadcrumbs";
import { getPublishedPosts } from "@/lib/posts";
import { webPageSchema } from "@/lib/seo";
import { getPostTagGroups } from "@/lib/tags";

export async function getStaticPaths() {
  const tags = getPostTagGroups(await getPublishedPosts());

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const path = `/tags/${tag.slug}`;
const description = `Posts tagged ${tag.label}.`;
const structuredData = webPageSchema({
  title: tag.label,
  description,
  path,
  type: "CollectionPage",
});
---

<Layout
  title={tag.label}
  description={description}
  canonicalPath={path}
  breadcrumbs={tagBreadcrumbs(tag)}
  structuredData={structuredData}
>
  <div class="site-frame py-12 sm:py-16">
    <a
      href="/tags"
      class="text-sm text-foreground-muted underline-offset-2 hover:text-foreground hover:underline hover:decoration-dotted"
      >&larr; All tags</a
    >

    <div class="mt-6">
      <PageHeader title={tag.label} subtitle={description} />
    </div>

    <div class="mt-12 grid gap-2 sm:grid-cols-2">
      {tag.posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</Layout>
