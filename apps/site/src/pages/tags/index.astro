---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { getPublishedPosts } from "@/lib/posts";
import { webPageSchema } from "@/lib/seo";
import { getPostTagGroups } from "@/lib/tags";

const tags = getPostTagGroups(await getPublishedPosts());
const structuredData = webPageSchema({
  title: "Tags",
  description: "Browse posts by topic.",
  path: "/tags",
  type: "CollectionPage",
});
---

<Layout
  title="Tags"
  description="Browse posts by topic."
  canonicalPath="/tags"
  breadcrumbs={pageBreadcrumbs("Tags", "/tags")}
  structuredData={structuredData}
>
  <div class="site-frame py-10">
    <div class="mb-10 flex max-w-2xl flex-col gap-3">
      <h1 class="text-pretty text-2xl font-medium tracking-normal text-foreground xl:text-3xl">
        Browse posts by topic.
      </h1>
      <p class="text-pretty text-lg/7 font-medium tracking-normal text-foreground-muted xl:text-xl/8">
        Tags from the posts I've published so far.
      </p>
    </div>

    {tags.length === 0 ? (
      <p class="text-foreground-muted">No tags yet. Check back soon.</p>
    ) : (
      <div class="grid gap-2 sm:grid-cols-2">
        {tags.map((tag) => (
          <a
            class="flex h-full min-h-32 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
            href={`/tags/${tag.slug}`}
          >
            <h2 class="text-lg/6 font-medium tracking-normal text-foreground">
              {tag.label}
            </h2>
            <p class="mt-3 text-base/7 text-foreground-muted">
              {tag.count} {tag.count === 1 ? "post" : "posts"}
            </p>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
