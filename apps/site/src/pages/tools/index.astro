---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import PageHeader from "@/components/page/PageHeader.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { webPageSchema } from "@/lib/seo";

const structuredData = webPageSchema({
  title: "Tools",
  description: "Free tools for SEO and AI.",
  path: "/tools",
  type: "CollectionPage",
});
---

<Layout
  title="Tools"
  description="Free tools for SEO and AI."
  canonicalPath="/tools"
  breadcrumbs={pageBreadcrumbs("Tools", "/tools")}
  structuredData={structuredData}
>
  <div class="site-frame py-12 sm:py-16">
    <PageHeader title="Tools" subtitle="Free tools for SEO and AI.">
      <p class="text-foreground-muted">
        Nothing here yet, but the first ones are on the way.
      </p>
    </PageHeader>

    <div class="mt-12">
      <Newsletter
        heading="Be first to try them"
        description="Subscribe and I'll email you when new tools go live."
      />
    </div>
  </div>
</Layout>
