---
export const prerender = true;

import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import TagLink from "@/components/primitives/TagLink.astro";
import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import { postBreadcrumbs } from "@/lib/breadcrumbs";
import { formatPostDate, getPublishedPosts } from "@/lib/posts";
import { blogPostingSchema } from "@/lib/seo";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"posts"> };
const { post } = Astro.props as Props;
const { Content } = await render(post);
const path = `/post/${post.id}`;

const structuredData = blogPostingSchema({
  title: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  path,
});
---

<Layout
  title={post.data.title}
  description={post.data.description}
  ogTitle={post.data.ogTitle}
  ogDescription={post.data.ogDescription}
  canonicalPath={path}
  ogType="article"
  breadcrumbs={postBreadcrumbs(post)}
  structuredData={structuredData}
>
  <article class="site-frame py-12 sm:py-16">
    <div class="flex flex-col gap-2">
      <time class="tracking-tighter text-foreground-soft" datetime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}>
        {formatPostDate(post.data.updatedDate ?? post.data.pubDate)}
      </time>
      <h1 class="text-3xl/tight font-medium text-foreground sm:text-4xl">
        {post.data.title}
      </h1>
      {post.data.tags.length > 0 ? (
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-foreground-soft">
          {post.data.tags.map((tag: string) => (
            <TagLink tag={tag} />
          ))}
        </div>
      ) : null}
    </div>

    <div class="content-prose mt-10">
      <Content />
    </div>

    <div class="mt-16">
      <Newsletter
        heading="Get the next one"
        description="Subscribe and I'll email you when I publish something new."
        source={`ian.is/post/${post.id}`}
      />
    </div>
  </article>
</Layout>
