---
interface Props {
  size?: number;
  /** id of the element this button expands (for aria-controls). */
  controls?: string;
  class?: string;
}
const { size = 24, controls, class: className } = Astro.props;
---

<button
  type="button"
  class:list={[
    "group/menu inline-flex items-center justify-center text-foreground",
    "transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background",
    className,
  ]}
  x-data="menuToggle"
  x-on:click="toggle"
  aria-label="Toggle menu"
  aria-expanded="false"
  x-bind:aria-expanded="String(open)"
  aria-controls={controls}
>
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class="overflow-visible" aria-hidden="true">
    <path
      d="M5 8H19"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      class="[transform-box:view-box] origin-[12px_8px] transition-transform duration-200 ease-in-out motion-reduce:transition-none group-aria-expanded/menu:[transform:translateY(4px)_rotate(45deg)_scaleX(1.2)]"
    />
    <path
      d="M5 16H19"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      class="[transform-box:view-box] origin-[12px_16px] transition-transform duration-200 ease-in-out motion-reduce:transition-none group-aria-expanded/menu:[transform:translateY(-4px)_rotate(-45deg)_scaleX(1.2)]"
    />
  </svg>
</button>
