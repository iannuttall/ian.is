---
type Props = {
  size?: string | number;
  strokeWidth?: string | number;
  [key: string]: unknown;
};

const { size = 20, strokeWidth = 2.5, ...props } = Astro.props as Props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  {...props}
>
  <path d="M5 8H19" stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round" />
  <path d="M5 16H19" stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round" />
</svg>
