---
type Props = {
  title: string;
};

import PageRail from "@/components/page/PageRail.astro";

const { title } = Astro.props;
---

<section class="flex flex-col bg-background pt-4 text-foreground">
  <PageRail
    class="group/page-hero"
    leftClass="bottom-16 sm:bottom-24"
    rightClass="top-[calc(50%+2rem)] -translate-y-1/2"
  >
    <Fragment slot="left">
      <slot name="left" />
    </Fragment>
    <div class="flex flex-col gap-8 pt-16 pb-16 sm:pt-24 sm:pb-24">
      <div class="flex max-w-2xl flex-col gap-4">
        <h1 class="max-w-xl text-pretty text-3xl font-medium -tracking-[0.5px] xl:text-4xl xl:-tracking-[0.7px]">
          {title}
        </h1>
        <div class="text-pretty text-2xl/8 font-medium -tracking-[0.2px] text-foreground-muted xl:text-3xl/10 xl:-tracking-[0.4px] [&>p+p]:mt-4 [&>p]:m-0">
          <slot />
        </div>
      </div>
    </div>
    <Fragment slot="right">
      <slot name="right" />
    </Fragment>
  </PageRail>
</section>
