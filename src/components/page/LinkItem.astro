---
type Props = {
  title: string;
  href?: string;
  meta?: string;
};

const { title, href = "#", meta } = Astro.props;
---

<li class="flex">
  <a href={href} class="group/list-item inline-flex flex-1 items-baseline gap-2 no-underline">
    <span class="text-xl leading-[1.6] font-medium tracking-normal text-foreground underline-offset-1 group-hover/list-item:underline group-hover/list-item:decoration-dotted">
      {title}
    </span>
    <span class="hidden text-xl leading-[1.6] font-medium tracking-normal text-foreground-muted sm:inline [&>p]:m-0">
      <slot />
    </span>
    {meta ? (
      <span class="ml-auto hidden shrink-0 text-xl leading-[1.6] font-medium tracking-normal text-foreground-soft sm:inline">
        {meta}
      </span>
    ) : null}
  </a>
</li>
