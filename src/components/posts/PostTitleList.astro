---
type Props = {
  posts: {
    id: string;
    data: {
      title: string;
    };
  }[];
  headingLevel?: "h2" | "h3";
};

const { posts, headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
const listClass = "flex flex-col gap-4 sm:gap-1.5";
const itemClass = "flex";
const linkClass = "group/list-item inline-flex flex-1 items-center gap-2 no-underline";
const titleClass =
  "line-clamp-none text-pretty text-xl leading-[1.6] font-medium tracking-normal text-foreground underline-offset-1 group-hover/list-item:underline group-hover/list-item:decoration-dotted";
---

<ul class={listClass}>
  {
    posts.map((post) => (
      <li class={itemClass}>
        <a href={`/post/${post.id}`} class={linkClass}>
          <Heading class={titleClass}>{post.data.title}</Heading>
        </a>
      </li>
    ))
  }
</ul>
