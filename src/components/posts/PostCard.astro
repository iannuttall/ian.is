---
import { formatPostDate } from "@/lib/posts";

type Props = {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
    };
  };
  headingLevel?: "h2" | "h3";
};

const { post, headingLevel = "h2" } = Astro.props;
---

<a
  class="flex h-full min-h-52 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
  href={`/post/${post.id}`}
>
  <p class="text-sm/6 text-foreground-soft">
    {formatPostDate(post.data.pubDate)}
  </p>
  {
    headingLevel === "h3" ? (
      <h3 class="mt-6 text-lg/6 font-medium tracking-normal text-foreground">
        {post.data.title}
      </h3>
    ) : (
      <h2 class="mt-6 text-lg/6 font-medium tracking-normal text-foreground">
        {post.data.title}
      </h2>
    )
  }
  <p class="mt-3 text-base/7 text-foreground-muted">
    {post.data.description}
  </p>
</a>
