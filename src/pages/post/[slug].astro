---
export const prerender = true;

import { render } from "astro:content";
import TagLink from "@/components/primitives/TagLink.astro";
import Layout from "@/layouts/Layout.astro";
import { formatPostDate, getPublishedPosts } from "@/lib/posts";
import { siteName, toAbsoluteUrl } from "@/lib/site";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/post/${post.id}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  url: toAbsoluteUrl(path),
  mainEntityOfPage: toAbsoluteUrl(path),
  author: { "@type": "Person", name: siteName },
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={path}
  ogType="article"
  structuredData={structuredData}
>
  <article class="site-frame py-12 sm:py-16">
    <a
      href="/posts"
      class="text-sm text-foreground-muted underline-offset-4 hover:text-foreground hover:underline"
      >&larr; All posts</a
    >

    <header class="mt-6">
      <h1 class="text-3xl/tight font-semibold text-foreground sm:text-4xl">
        {post.data.title}
      </h1>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-foreground-soft">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatPostDate(post.data.pubDate)}
        </time>
        {post.data.tags.length > 0 ? (
          <span class="text-foreground-soft">·</span>
        ) : null}
        {post.data.tags.map((tag) => (
          <TagLink tag={tag} />
        ))}
      </div>
    </header>

    <div class="content-prose mt-10">
      <Content />
    </div>
  </article>
</Layout>
