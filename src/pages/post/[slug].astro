---
export const prerender = true;

import { render } from "astro:content";
import TagLink from "@/components/primitives/TagLink.astro";
import Layout from "@/layouts/Layout.astro";
import { postBreadcrumbs } from "@/lib/breadcrumbs";
import { formatPostDate, getPublishedPosts } from "@/lib/posts";
import { siteName, toAbsoluteUrl } from "@/lib/site";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const path = `/post/${post.id}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  url: toAbsoluteUrl(path),
  mainEntityOfPage: toAbsoluteUrl(path),
  author: { "@type": "Person", name: siteName },
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={path}
  ogType="article"
  breadcrumbs={postBreadcrumbs(post)}
  structuredData={structuredData}
>
  <article class="site-frame py-12 sm:py-16">
    <header class="flex flex-col gap-2">
      <time class="text-foreground-soft" datetime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}>
        {formatPostDate(post.data.updatedDate ?? post.data.pubDate)}
      </time>
      <h1 class="text-3xl/tight font-medium text-foreground sm:text-4xl">
        {post.data.title}
      </h1>
      {post.data.tags.length > 0 ? (
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-foreground-soft">
          {post.data.tags.map((tag) => (
            <TagLink tag={tag} />
          ))}
        </div>
      ) : null}
    </header>

    <div class="content-prose mt-10">
      <Content />
    </div>
  </article>
</Layout>
