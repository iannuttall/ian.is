---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import { Newsletter } from "@/components/islands/Newsletter";
import { formatPostDate, getPublishedPosts } from "@/lib/posts";
import { webPageSchema } from "@/lib/seo";

const posts = await getPublishedPosts();
const structuredData = webPageSchema({
  title: "Posts",
  description: "Writing on SEO, AI, and building tools.",
  path: "/posts",
  type: "CollectionPage",
});
---

<Layout
  title="Posts"
  description="Writing on SEO, AI, and building tools."
  canonicalPath="/posts"
  structuredData={structuredData}
>
  <div class="site-frame py-10">
    <header class="mb-10 flex max-w-2xl flex-col gap-3">
      <h1 class="text-pretty text-2xl font-medium tracking-normal text-foreground xl:text-3xl">
        Notes on SEO, AI, and building tools.
      </h1>
      <p class="text-pretty text-lg/7 font-medium tracking-normal text-foreground-muted xl:text-xl/8">
        Guides and experiments from the things I'm working on.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="text-foreground-muted">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid gap-2 sm:grid-cols-2">
        {posts.map((post) => (
          <a
            class="flex h-full min-h-52 flex-col rounded-lg bg-muted p-6 no-underline transition-colors hover:bg-secondary-hover"
            href={`/post/${post.id}`}
          >
            <p class="text-sm/6 text-foreground-soft">
              {formatPostDate(post.data.pubDate)}
            </p>
            <h2 class="mt-6 text-lg/6 font-medium tracking-normal text-foreground">
              {post.data.title}
            </h2>
            <p class="mt-3 text-base/7 text-foreground-muted">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>
    )}

    <div class="mt-16">
      <Newsletter client:visible />
    </div>
  </div>
</Layout>
