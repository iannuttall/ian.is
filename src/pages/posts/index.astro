---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import PostTitleList from "@/components/posts/PostTitleList.astro";
import { pageBreadcrumbs } from "@/lib/breadcrumbs";
import { getPublishedPosts } from "@/lib/posts";
import { webPageSchema } from "@/lib/seo";

const posts = await getPublishedPosts();
const structuredData = webPageSchema({
  title: "Posts",
  description: "Writing on SEO, AI, and building tools.",
  path: "/posts",
  type: "CollectionPage",
});
---

<Layout
  title="Posts"
  description="Writing on SEO, AI, and building tools."
  canonicalPath="/posts"
  breadcrumbs={pageBreadcrumbs("Posts", "/posts")}
  structuredData={structuredData}
>
  <div class="site-frame py-10">
    <header class="mb-8">
      <h1 class="text-pretty text-2xl/8 font-medium tracking-normal text-foreground-soft sm:text-3xl/10">
        Writing
      </h1>
    </header>

    {posts.length === 0 ? (
      <p class="text-foreground-muted">No posts yet. Check back soon.</p>
    ) : (
      <PostTitleList posts={posts} />
    )}

    <div class="mt-16">
      <Newsletter />
    </div>
  </div>
</Layout>
