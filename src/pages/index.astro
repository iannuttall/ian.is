---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Newsletter from "@/components/Newsletter.astro";
import PostCard from "@/components/posts/PostCard.astro";
import { getPublishedPosts } from "@/lib/posts";
import { webSiteSchema } from "@/lib/seo";

const posts = (await getPublishedPosts()).slice(0, 4);
---

<Layout
  title="Ian Nuttall"
  description="Notes, tools, and experiments with SEO and AI, from Ian Nuttall."
  canonicalPath="/"
  structuredData={webSiteSchema()}
>
  <section class="flex flex-col border-b border-border bg-background pt-4 text-foreground">
    <div class="site-frame">
      <div class="flex flex-col gap-8 pt-16 sm:pt-24">
        <div class="flex max-w-2xl flex-col gap-4">
          <h1 class="max-w-xl text-pretty text-3xl font-medium -tracking-[0.5px] xl:text-4xl xl:-tracking-[0.7px]">
            Notes, tools, and experiments with SEO and AI.
          </h1>
          <p class="text-pretty text-2xl/8 font-medium -tracking-[0.2px] text-foreground-muted xl:text-3xl/10 xl:-tracking-[0.4px]">
            I'm Ian Nuttall. I write about search, AI, and building small useful
            things &mdash; and I send the good stuff to my newsletter first.
          </p>
        </div>
        <Newsletter standalone={false} />
      </div>
    </div>
  </section>

  <div class="space-y-24 py-24">
    <section class="site-frame">
      <div class="mb-10 flex items-end justify-between gap-4">
        <h2 class="text-pretty text-2xl font-medium -tracking-[0.4px] text-foreground xl:text-3xl xl:-tracking-[0.6px]">
          Latest posts
        </h2>
        <a
          href="/posts"
          class="shrink-0 text-sm text-foreground-muted underline-offset-4 hover:text-foreground hover:underline"
          >All posts</a
        >
      </div>

      {posts.length === 0 ? (
        <p class="text-foreground-muted">No posts yet. Check back soon.</p>
      ) : (
        <div class="grid gap-2 sm:grid-cols-2">
          {posts.map((post) => (
            <PostCard post={post} headingLevel="h3" />
          ))}
        </div>
      )}
    </section>
  </div>
</Layout>
